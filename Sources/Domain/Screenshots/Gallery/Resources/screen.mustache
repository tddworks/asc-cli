{{{themeVars}}}<div data-theme="{{theme}}" style="background:{{background}};position:relative;overflow:hidden;container-type:inline-size;width:100%;height:100%">{{#tagline}}<div style="position:absolute;top:{{top}}%;left:{{pad}}%;right:{{pad}}%;z-index:4;font-weight:{{weight}};font-size:{{fontSize}}cqi;color:{{color}};letter-spacing:0.1em;text-transform:uppercase;text-align:{{align}};white-space:pre-line">{{{content}}}</div>{{/tagline}}{{#headline}}<div style="position:absolute;top:{{top}}%;left:{{pad}}%;right:{{pad}}%;z-index:4;font-weight:{{weight}};font-size:{{fontSize}}cqi;color:{{color}};line-height:0.92;letter-spacing:-0.03em;text-align:{{align}};white-space:pre-line">{{{content}}}</div>{{/headline}}{{#subheading}}<div style="position:absolute;top:{{top}}%;left:{{pad}}%;right:{{padRight}}%;z-index:4;font-weight:{{weight}};font-size:{{fontSize}}cqi;color:var(--body-color);line-height:1.4;text-align:{{align}}">{{{content}}}</div>{{/subheading}}{{#trustMarks}}<div style="position:absolute;top:{{top}}%;left:{{pad}}%;z-index:4;display:flex;gap:4px;flex-wrap:wrap">{{#items}}<span style="background:var(--badge-bg);border-radius:5px;padding:0.3cqi 0.8cqi;font-size:{{fontSize}}cqi;font-weight:700;color:var(--trust-color);letter-spacing:0.04em">{{text}}</span>{{/items}}</div>{{/trustMarks}}{{#badges}}<div style="position:absolute;left:{{left}}%;top:{{top}}%;z-index:5;background:var(--badge-bg);border:1px solid var(--badge-border);border-radius:100px;padding:0.3cqi 0.8cqi;font-size:{{fontSize}}cqi;font-weight:700;color:var(--badge-color);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);white-space:nowrap">{{text}}</div>{{/badges}}{{#devices}}{{#hasScreenshot}}<div style="position:absolute;left:{{left}}%;top:{{top}}%;width:{{width}}%;z-index:2"><img src="{{screenshot}}" style="width:100%;display:block" alt=""></div>{{/hasScreenshot}}{{#hasWireframe}}<div style="position:absolute;left:{{left}}%;top:{{top}}%;width:{{width}}%;z-index:2">{{#hasPhoneFrame}}<div style="aspect-ratio:1470/3000;position:relative;filter:drop-shadow(0 4px 20px rgba(0,0,0,var(--shadow-opacity)))">{{{wireframeHTML}}}<img src="{{phoneFrameURL}}" style="position:absolute;inset:0;width:100%;height:100%;z-index:2;pointer-events:none" alt=""></div>{{/hasPhoneFrame}}{{#noPhoneFrame}}<div style="aspect-ratio:1470/3000;position:relative;filter:drop-shadow(0 4px 20px rgba(0,0,0,var(--shadow-opacity)));background:var(--frame-bg);border-radius:12%/5.5%;border:1.5px solid var(--frame-border);overflow:hidden">{{{wireframeHTML}}}</div>{{/noPhoneFrame}}</div>{{/hasWireframe}}{{/devices}}{{#decorations}}<div style="position:absolute;left:{{left}}%;top:{{top}}%;z-index:3;font-size:{{fontSize}}cqi;opacity:{{opacity}};background:{{background}};color:{{#useDefaultColor}}var(--deco-color){{/useDefaultColor}}{{color}};border-radius:{{borderRadius}};padding:0.3cqi 0.8cqi;pointer-events:none;white-space:nowrap;{{animStyle}}">{{{content}}}</div>{{/decorations}}{{#hasAnimations}}{{{keyframesHTML}}}{{/hasAnimations}}</div>