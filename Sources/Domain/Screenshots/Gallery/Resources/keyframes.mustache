<style>
@keyframes td-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes td-drift{0%,100%{transform:translate(0,0)}50%{transform:translate(5px,-5px)}}
@keyframes td-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
@keyframes td-spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes td-twinkle{0%,100%{opacity:0.5}50%{opacity:0.8}}
</style>